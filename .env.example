# Application
ENVIRONMENT=development
# Defaults to http://localhost:8000; Compose also derives the port from APP_PORT.
# PUBLIC_BASE_URL=https://short.example.com
WEB_CONCURRENCY=4

# Accounts and private dashboards. Use a long random value in production.
AUTH_REQUIRED=false
AUTH_RATE_LIMIT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
SESSION_SECRET=replace-with-a-long-random-secret-before-deploying
SESSION_COOKIE_SECURE=false
SESSION_MAX_AGE_SECONDS=604800

# PostgreSQL (used directly by local processes)
DATABASE_URL=postgresql+psycopg2://snaplink:snaplink@localhost:5432/snaplink
# Alternatively set DATABASE_HOST/PORT/USER/PASSWORD/NAME; this safely handles
# credentials containing URL-reserved characters.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_CONNECT_TIMEOUT=2
DB_HEALTH_STATEMENT_TIMEOUT_MS=1000

# Redis
# Local development can share one server. Role-specific URLs override this
# fallback; Compose supplies separate cache and limiter services.
REDIS_URL=redis://localhost:6379/0
# REDIS_CACHE_URL=redis://localhost:6379/0
# REDIS_RATE_LIMIT_URL=redis://localhost:6380/0
REDIS_MAX_CONNECTIONS=50
REDIS_CACHE_TTL=86400
REDIS_NEGATIVE_CACHE_TTL=60
REDIS_REQUIRED=false

# Per-client write rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_FAIL_OPEN=true

# Short-code generation
SHORT_CODE_LENGTH=10
SHORT_CODE_MAX_ATTEMPTS=10

# Set for multi-worker deployments only, using a fresh empty directory.
# PROMETHEUS_MULTIPROC_DIR=/tmp/snaplink-prometheus

# Docker Compose development settings
POSTGRES_USER=snaplink
POSTGRES_PASSWORD=snaplink
POSTGRES_DB=snaplink
POSTGRES_PORT=5432
POSTGRES_MAX_CONNECTIONS=200
REDIS_PORT=6379
REDIS_RATE_LIMIT_PORT=6380
REDIS_CACHE_MAXMEMORY=256mb
REDIS_CACHE_MAXMEMORY_POLICY=volatile-lru
REDIS_RATE_LIMIT_MAXMEMORY=128mb
APP_PORT=8000

# Trust proxy headers only from these comma-separated proxy IPs/CIDRs.
FORWARDED_ALLOW_IPS=127.0.0.1
